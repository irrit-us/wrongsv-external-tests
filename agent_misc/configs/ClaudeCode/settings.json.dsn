{
  "env": {
    "ANTHROPIC_MODEL": "claude-opus-4-7",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-sonnet-4",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "MAX_THINKING_TOKENS": "24000",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "460000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "40000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "16000",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "16",
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DISABLE_ATTACHMENTS": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "600000",
    "BASH_MAX_OUTPUT_LENGTH": "12000",
    "LC_ALL": "C.UTF-8",
    "LANG": "C.UTF-8",
    "TERM": "xterm-256color",
    "COLORTERM": "truecolor"
  },
  "permissions": {
    "allow": [
      "Bash(wget *)"
    ],
    "defaultMode": "bypassPermissions"，
    "skipDangerousModePermissionPrompt": true
  },
  "model": "claude-opus-4-7",
  "skipDangerousModePermissionPrompt": true,
  "awaySummaryEnabled": true,
  "cleanupPeriodDays": 90,
  "theme": "dark-daltonized",
  "editorMode": "normal",
  "verbose": false,
  "showTurnDuration": true,
  "terminalProgressBarEnabled": false,
  "autoScrollEnabled": false,
  "externalEditorContext": true,
  "includeCoAuthoredBy": false,
  "skipWebFetchPreflight": true
}
