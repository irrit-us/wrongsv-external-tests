{
  "env": {
    "ANTHROPIC_MODEL": "deepseek-v4-pro",
    "ANTHROPIC_SMALL_FAST_MODEL": "deepseek-v4-flash",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "MAX_THINKING_TOKENS": "32000",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "32000",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "16",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "320000",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_OUTPUT_LENGTH": "12000",
    "CLAUDE_CODE_DISABLE_ATTACHMENTS": "1",
    "LC_ALL": "C.UTF-8",
    "LANG": "C.UTF-8",
    "TERM": "xterm-256color",
    "COLORTERM": "truecolor"
  },
  "permissions": {
    "allow": [
      "Bash(wget *)"
    ],
    "defaultMode": "bypassPermissions",
    "skipDangerousModePermissionPrompt": true
  },
  "model": "claude-opus-4-6-thinking",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-language-server@claude-plugins-official": true
  },
  "awaySummaryEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWebFetchPreflight": true,
  "theme": "dark-daltonized",
  "editorMode": "normal",
  "verbose": false,
  "preferredNotifChannel": "false",
  "includeCoAuthoredBy": false
}
